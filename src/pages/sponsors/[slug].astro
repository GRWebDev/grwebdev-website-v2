---
import { getCollection, getEntry, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { withBase } from "../../utils/utils";

const { slug } = Astro.params;
const sponsor = await getEntry("sponsors", slug);
if (!sponsor) {
	return Astro.redirect("/404", 404);
}
const { Content } = await render(sponsor);
const sponsorImageTransitionStyle = `view-transition-name: ${sponsor.data.slug}-image`;
const sponsorTitleTransitionStyle = `view-transition-name: ${sponsor.data.slug}-title`;
export async function getStaticPaths() {
	const sponsors = await getCollection("sponsors");
	return sponsors.map((sponsor) => ({ params: { slug: sponsor.data.slug } }));
}
---

<style>
	:root {
		--direction: 1;
		@view-transition {
			navigation: auto;
			types: slider;
		}
	}
	img {
		object-fit: contain;
	}
</style>
<Layout title={`${sponsor?.data?.name ?? 'Sponsor Slug'}`}>
	<section class="grid">
		<div class="outdent image-text">
			<img
				src={sponsor.data.image.src === "" ? "https://placehold.co/300x150" : withBase(sponsor.data.image.src)}
				alt=""
				width="300"
				height="150"
				style={sponsorImageTransitionStyle}
			>
			<div>
				<h1 style={sponsorTitleTransitionStyle}>{sponsor.data.name}</h1>
				<Content />
			</div>
		</div>
	</section>
</Layout>
